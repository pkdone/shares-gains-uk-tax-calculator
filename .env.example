# Node environment: development | production | test
NODE_ENV=development

# MongoDB Atlas connection string (includes database name in URI path).
# Example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://user:password@cluster.example.mongodb.net/mydb?retryWrites=true&w=majority"

# Public site origin (no trailing slash). Used for trusted origins and client-side links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Better Auth API base URL (must be identical on server and client; include /api/auth).
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000/api/auth"
BETTER_AUTH_URL="http://localhost:3000/api/auth"

# Session signing secret — use a long random value in production (e.g. openssl rand -base64 32).
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"

# Transactional email: noop logs the full message (including verification/reset URLs) via app logger — copy the URL from the terminal when running `npm run dev`. Use a real provider in production.
AUTH_EMAIL_PROVIDER=noop

# Required for npm run db:teardown only (drops managed collections). Do not set in production.
# ALLOW_DB_TEARDOWN=1
